{
  "name": "phonograph",
  "version": "1.3.24",
  "description": "",
  "homepage": "/",
  "engines": {
    "node": ">=0.12"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@itsmeadarsh/warper": "^7.2.0",
    "@mui/icons-material": "^6.1.10",
    "@mui/material": "^6.1.10",
    "audioqueue": "^1.1.1",
    "colorthief": "^2.4.0",
    "dayjs": "^1.8.23",
    "dompurify": "^2.0.10",
    "encoding": "^0.1.12",
    "idb-keyval": "^3.2.0",
    "node-fetch": "^2.6.0",
    "podcastsuite": "1.1.9",
    "randomcolor": "^0.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intl": "^8.1.3",
    "react-router": "5.1.2",
    "react-router-dom": "^5.1.2",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "smallfetch": "^1.0.8",
    "xml2js": "^0.4.22",
    "zustand": "^5.0.3"
  },
  "private": true,
  "browserslist": [
    "last 1 Chrome versions"
  ],
  "scripts": {
    "start": "vite",
    "desktop:sync-version": "node scripts/sync-tauri-version.mjs",
    "desktop:dev": "yarn desktop:sync-version && tauri dev",
    "desktop:build": "yarn desktop:sync-version && tauri build",
    "build": "yarn getter && vite build && yarn SEO && yarn sw && yarn docs:manuals:build && yarn lambda:build",
    "serve": "vite preview",
    "docs:manuals:dev": "vitepress dev manuals",
    "docs:manuals:build": "vitepress build manuals --outDir dist/docs",
    "docs:manuals:preview": "vitepress preview manuals",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src lambda scripts vite.config.mjs vitest.config.mjs swGenerator.js proxy.js --files-ignore-unknown=true --max-diagnostics=200",
    "lint:errors": "biome lint src lambda scripts vite.config.mjs vitest.config.mjs swGenerator.js proxy.js --files-ignore-unknown=true --diagnostic-level=error",
    "lint:fix": "biome lint src lambda scripts vite.config.mjs vitest.config.mjs swGenerator.js proxy.js --write --unsafe --files-ignore-unknown=true --max-diagnostics=200",
    "format": "biome format . --write --files-ignore-unknown=true",
    "format:check": "biome format . --files-ignore-unknown=true",
    "quality": "yarn typecheck && yarn lint:errors && yarn test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "coverage:changed": "node scripts/check-changed-file-coverage.mjs",
    "SEO": "cp ./public/robots.txt ./dist/robots.txt",
    "bundle": "vite build",
    "lambda:build": "netlify functions:build --src ./lambda --functions .netlify/functions-dist",
    "lambda:serve": "netlify functions:serve --src ./lambda",
    "dev": "yarn getter && concurrently \"yarn lambda:serve\" \"vite\"",
    "getter": "bash ./filegetter.sh",
    "sw": "node swGenerator.js"
  },
  "alias": {
    "public": "/public/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@formatjs/cli": "^6.13.0",
    "@netlify/functions": "^5.1.2",
    "@tauri-apps/cli": "^2.9.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.2.3",
    "@types/node-fetch": "2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "5",
    "@vitejs/plugin-react": "^5.0.2",
    "babel-plugin-transform-object-rest-spread": "^6.26.0",
    "concurrently": "^9.2.1",
    "cz-conventional-changelog": "3.2.0",
    "express": "^4.17.1",
    "http-proxy-middleware": "^1.0.3",
    "netlify-cli": "^23.4.3",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitepress": "^1.6.3",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
